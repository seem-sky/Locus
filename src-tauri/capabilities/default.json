{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and auxiliary progress windows",
  "windows": [
    "main",
    "knowledge-download-progress",
    "knowledge-lexical-progress",
    "unity-reference-import-progress",
    "feishu-reference-import-progress",
    "reference-external-import",
    "collab-history-search",
    "chat-diff-review",
    "locus-asset-inspector",
    "unity-embed",
    "unity-embed-*",
    "view-*",
    "agent-graph-*"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-internal-toggle-devtools",
    "core:webview:allow-set-webview-background-color",
    "core:window:allow-create",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-background-color",
    "core:window:allow-get-all-windows",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-cursor-position",
    "core:webview:allow-set-webview-focus",
    "core:window:allow-set-always-on-top",
    "core:window:allow-is-always-on-top",
    "core:window:allow-set-closable",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$TEMP/**" }]
    },
    "dialog:default",
    "notification:default"
  ]
}
