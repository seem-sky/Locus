{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "locus",
  "version": "0.1.1",
  "identifier": "com.locus.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:14901",
    "beforeBuildCommand": "bun run build:tauri",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Locus",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 500,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../LICENSE": "licenses/LICENSE",
      "../THIRD_PARTY_NOTICES": "licenses/THIRD_PARTY_NOTICES",
      "./gen/licenses-bundle": "licenses/third_party/",
      "../agent": "agent/",
      "../knowledge": "knowledge/",
      "../locus_unity": "locus_unity/"
    }
  }
}
